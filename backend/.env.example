# Server Configuration
PORT=3001
NODE_ENV=development

# AWS Configuration
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here

# AWS Bedrock Configuration
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_REGION=us-west-2

# Firecrawl API Configuration
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
FIRECRAWL_BASE_URL=https://api.firecrawl.dev

# Perplexity API Configuration
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Tavily API Configuration
TAVILY_API_KEY=your_tavily_api_key_here

# Database Configuration (DynamoDB)
DYNAMODB_TABLE_PREFIX=pr-
DYNAMODB_JOBS_TABLE=pr-jobs
DYNAMODB_CONTENT_TABLE=pr-content

# S3 Configuration
S3_BUCKET_NAME=pr-generated-content
S3_REGION=us-west-2

# Redis Configuration (for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379
REDIS_TTL=3600
REDIS_TTL_REAL_ESTATE=21600
REDIS_TTL_ECONOMIC=86400
REDIS_TTL_NEWS=7200
REDIS_TTL_DEMOGRAPHICS=604800

# Data Collection Settings
DATA_REFRESH_INTERVAL=6
MAX_CONCURRENT_COLLECTIONS=10
DATA_QUALITY_THRESHOLD=80
DATA_RETRY_ATTEMPTS=3
DATA_RETRY_DELAY_MS=5000
DATA_BATCH_SIZE=5

# External API Keys
CENSUS_API_KEY=your_census_api_key_here
BLS_API_KEY=your_bls_api_key_here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/app.log

# API Configuration
API_VERSION=v1
MAX_FILE_SIZE=10485760
SUPPORTED_FILE_TYPES=.txt,.docx,.pdf

# Generation Configuration
MAX_CONCURRENT_GENERATIONS=5
GENERATION_TIMEOUT_MS=600000