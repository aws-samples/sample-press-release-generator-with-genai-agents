# Environment Configuration Template
# 100 Market Press Release Generator - GenAI Agents
# Copy this file to .env and fill in your actual values

# =============================================================================
# AWS ACCOUNT CONFIGURATION
# =============================================================================
AWS_PROFILE=your_aws_profile_name
AWS_REGION=us-west-2
AWS_ACCOUNT_ID=YOUR_AWS_ACCOUNT_ID

# =============================================================================
# AWS BEDROCK CONFIGURATION
# =============================================================================
AWS_BEDROCK_MODEL_ID=your_bedrock_model_id
AWS_BEDROCK_REGION=us-west-2
AWS_BEDROCK_MAX_INPUT_TOKENS=1000000
AWS_BEDROCK_MAX_OUTPUT_TOKENS=64000
AWS_BEDROCK_TEMPERATURE=0.7
AWS_BEDROCK_API_TIMEOUT=600000

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
NODE_ENV=development
PORT=3001
API_VERSION=v1

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_CREDENTIALS=true
CORS_MAX_AGE=86400

# =============================================================================
# EXTERNAL API KEYS (REQUIRED - OBTAIN FROM SECURE SOURCES)
# =============================================================================
# CRITICAL: These API keys must be obtained from their respective providers
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
PERPLEXITY_API_KEY=your_perplexity_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# Optional API Keys for enhanced functionality
BLS_API_KEY=your_bls_api_key_here
CENSUS_API_KEY=your_census_api_key_here

# =============================================================================
# EXTERNAL SERVICE CONFIGURATION
# =============================================================================
FIRECRAWL_BASE_URL=https://api.firecrawl.dev
PERPLEXITY_BASE_URL=https://api.perplexity.ai
PERPLEXITY_MODEL=llama-3.1-sonar-small-128k-online
TAVILY_BASE_URL=https://api.tavily.com
TAVILY_MAX_RESULTS=10
TAVILY_SEARCH_DEPTH=basic

# =============================================================================
# STORAGE CONFIGURATION
# =============================================================================
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./storage/generated

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_MODE=local
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379
REDIS_TTL=3600

# =============================================================================
# DATA PROCESSING CONFIGURATION
# =============================================================================
DATA_BATCH_SIZE=10
MAX_CONCURRENT_COLLECTIONS=5
MAX_CONCURRENT_GENERATIONS=3
GENERATION_TIMEOUT_MS=120000

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=info
LOG_FILE=./logs/application/app.log
LOG_FORMAT=json