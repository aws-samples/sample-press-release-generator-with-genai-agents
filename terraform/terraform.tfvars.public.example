# Public Deployment Configuration Example
# Copy this file to terraform.tfvars and customize for your public deployment

# Basic Configuration
project_name = "press-release-generator"
environment  = "prod"
aws_region   = "us-west-2"

# Deployment Type - PUBLIC (Internet-facing)
deployment_type = "public"

# Application Configuration
backend_image  = "nginx:alpine"  # Will be replaced with ECR URL after deployment
frontend_image = "nginx:alpine"  # Will be replaced with ECR URL after deployment

# CORS Configuration for Public Deployment
frontend_url = "https://yourdomain.com"  # Optional: Set your custom domain
cors_allowed_origins = "https://*.cloudfront.net,https://*.elb.amazonaws.com,https://yourdomain.com"

# SSL/TLS Configuration (Optional)
# ssl_certificate_arn = "arn:aws:acm:us-west-2:123456789012:certificate/12345678-1234-1234-1234-123456789012"
# domain_name = "api.yourdomain.com"

# Resource Sizing
backend_cpu    = 512
backend_memory = 1024
backend_desired_count = 2

frontend_cpu    = 256
frontend_memory = 512
frontend_desired_count = 2

# Auto Scaling
backend_min_capacity  = 1
backend_max_capacity  = 10
frontend_min_capacity = 1
frontend_max_capacity = 5

# Security Configuration
allowed_cidr_blocks = ["0.0.0.0/0"]  # Public access from anywhere

# AWS Bedrock Configuration
aws_bedrock_model_id = "global.anthropic.claude-sonnet-4-5-20250929-v1:0"

# Secrets (Optional - provide ARNs if you have API keys stored in AWS Secrets Manager)
# firecrawl_api_key_secret_arn = "arn:aws:secretsmanager:us-west-2:123456789012:secret:firecrawl-api-key-AbCdEf"
# perplexity_api_key_secret_arn = "arn:aws:secretsmanager:us-west-2:123456789012:secret:perplexity-api-key-GhIjKl"

# Additional Tags
additional_tags = {
  Owner       = "DevOps Team"
  CostCenter  = "Engineering"
  Backup      = "Daily"

# Performance Comparison Configuration
}